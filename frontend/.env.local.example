# =============================================================================
# Drip frontend — environment configuration
# =============================================================================
# Copy this file to .env.local and fill in the deployed contract addresses.

# After running `npm run deploy:testnet` in contracts/, paste those addresses here:
NEXT_PUBLIC_DRIP_ADDRESS=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_DRIP_POLICIES_ADDRESS=0x0000000000000000000000000000000000000000

# Network — testnet for development, mainnet for production
NEXT_PUBLIC_NETWORK=somnia-testnet
